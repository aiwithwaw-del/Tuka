generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String       @id @default(uuid())
  phone       String       @unique
  name        String?
  role        Role         @default(USER)
  challenges  Challenge[]  @relation("SponsorChallenges")
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

enum Role {
  USER
  SPONSOR
  ADMIN
}

model Challenge {
  id            String       @id @default(uuid())
  sponsorId     String
  sponsor       User         @relation("SponsorChallenges", fields: [sponsorId], references: [id])
  title         String
  description   String
  rewardPool    Int
  feePercent    Float        @default(0.05)
  locationType  LocationType @default(REMOTE)
  city          String?
  lat           Float?
  lng           Float?
  radiusMeters  Int          @default(5000)
  status        String       @default("ACTIVE")
  submissions   Submission[]
  createdAt     DateTime     @default(now())
}

enum LocationType {
  REMOTE
  PHYSICAL
  GEO_FENCED
}

model Submission {
  id              String    @id @default(uuid())
  challengeId     String
  challenge       Challenge @relation(fields: [challengeId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  proofText       String?
  proofFileUrl    String?
  proofType       String?
  userLat         Float?
  userLng         Float?
  status          String    @default("PENDING")
  rejectionReason String?
  submittedAt     DateTime  @default(now())
  approvedAt      DateTime?
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  createdAt DateTime @default(now())
}
