generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Using SQLite for Phase 1 MVP (zero setup). Switch to PostgreSQL later.
  url      = "file:./dev.db"
}

model User {
  id          String       @id @default(uuid())
  phone       String       @unique
  name        String?
  role        Role         @default(USER)
  challenges  Challenge[]  @relation("SponsorChallenges")
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

enum Role {
  USER
  SPONSOR
  ADMIN
}

model Challenge {
  id            String       @id @default(uuid())
  sponsorId     String
  sponsor       User         @relation("SponsorChallenges", fields: [sponsorId], references: [id])
  title         String
  description   String
  rewardPool    Int          // Total UGX
  feePercent    Float        @default(0.05) // 5%
  locationType  LocationType @default(REMOTE)
  city          String?
  lat           Float?
  lng           Float?
  radiusMeters  Int          @default(5000) // Default 5km
  status        String       @default("ACTIVE") // DRAFT, ACTIVE, COMPLETED
  submissions   Submission[]
  createdAt     DateTime     @default(now())
}

enum LocationType {
  REMOTE
  PHYSICAL
  GEO_FENCED
}

model Submission {
  id          String    @id @default(uuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  proofText   String?   // e.g., "Posted link: https..."
  userLat     Float?    // Where the user submitted from
  userLng     Float?
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g., "CHALLENGE_CREATED", "SUBMISSION_APPROVED"
  details   String   // JSON string of what happened
  createdAt DateTime @default(now())
}
